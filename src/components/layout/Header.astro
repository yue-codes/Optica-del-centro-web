---
import MobileMenu from "./MobileMenu.tsx";

const navLinks = [
  { href: "#servicios", label: "Servicios" },
  { href: "#mision", label: "Misión" },
  { href: "#sucursales", label: "Sucursales" },
  { href: "#contacto", label: "Contacto" },
];

const whatsappUrl =
  "https://wa.me/529511398701?text=Hola%2C%20me%20gustar%C3%ADa%20agendar%20una%20cita";
---

<!-- Velocidad de transición: duration-500. Auméntala (ej. duration-700) para más lento, bájala (ej. duration-300) para más rápido -->
<header
  id="main-header"
  class="fixed top-0 z-50 w-full transition-all duration-500"
>
  <!-- Padding vertical: py-2 móvil / py-4 desktop. Ajusta py-2 para más/menos altura en móvil -->
  <div
    class="relative mx-auto flex max-w-7xl items-center justify-between px-6 py-2 lg:py-4"
  >
    <!-- Logo -->
    <a href="/" class="shrink-0">
      <img
        src="/logo-300x259.png"
        alt="Óptica del Centro"
        class="h-12 w-auto"
      />
    </a>

    <!-- Nav desktop -->
    <nav class="hidden items-center gap-8 lg:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link text-sm font-medium transition-colors duration-300"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-[#25D366] px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-green-200 transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#1ebe59]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="h-4 w-4 shrink-0"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        Agendar cita
      </a>
    </nav>

    <!-- Mobile menu -->
    <MobileMenu client:load />
  </div>
</header>

<style>
  #main-header {
    background-color: transparent;
  }

  /* Transparencia del header al hacer scroll: 0.75 = 75% opaco. Sube para más sólido, baja para más transparente */
  #main-header.scrolled {
    background-color: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(226, 232, 240, 0.4);
    box-shadow: 0 1px 20px rgba(0, 0, 0, 0.06);
  }

  /* Links transparente → blancos */
  #main-header:not(.scrolled) .nav-link {
    color: rgba(255, 255, 255, 0.85);
  }
  #main-header:not(.scrolled) .nav-link:hover {
    color: #ffffff;
  }

  /* Links scrolled → slate */
  #main-header.scrolled .nav-link {
    color: #475569;
  }
  #main-header.scrolled .nav-link:hover {
    color: #1b3a5c;
  }

  /* Hamburger transparente → blanco */
  #main-header:not(.scrolled) :global(.hamburger-btn) {
    color: white;
  }
  #main-header:not(.scrolled) :global(.hamburger-btn:hover) {
    background-color: rgba(255, 255, 255, 0.15);
  }

  /* Hamburger scrolled → primary */
  #main-header.scrolled :global(.hamburger-btn) {
    color: #1b3a5c;
  }
  #main-header.scrolled :global(.hamburger-btn:hover) {
    background-color: #f1f5f9;
  }
</style>

<script>
  const header = document.getElementById("main-header")!;

  function updateHeader() {
    header.classList.toggle("scrolled", window.scrollY > 50);
  }

  window.addEventListener("scroll", updateHeader, { passive: true });
  updateHeader();
</script>
