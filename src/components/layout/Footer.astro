---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Columna 1: Marca -->
    <div class="space-y-4">
      <img
        src="/logo-300x259.png"
        alt="Óptica del Centro"
        class="h-16 w-auto brightness-0 invert"
      />
      <p class="text-slate-300 text-sm leading-relaxed max-w-xs">
        Cuidamos tu salud visual integral con servicio médico y óptico de
        calidad en el Valle de Oaxaca.
      </p>
      <div class="flex gap-3 pt-2">
        {
          socialLinks.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.label}
              class="w-9 h-9 rounded-full bg-white/10 hover:bg-accent flex items-center justify-center transition-colors duration-200"
              set:html={s.icon}
            />
          ))
        }
      </div>
    </div>

    <!-- Columna 2: Sucursales -->
    <div class="space-y-5">
      <h3 class="font-bold text-base tracking-wide">Sucursales</h3>
      <div class="space-y-4 text-sm">
        <div>
          <p class="font-semibold text-accent mb-1">Tlacolula</p>
          <p class="text-slate-300 leading-relaxed">
            Nicolás Bravo #13, Tlacolula de Matamoros, 70400, Oaxaca.
          </p>
        </div>
        <div>
          <p class="font-semibold text-accent mb-1">Ocotlán</p>
          <p class="text-slate-300 leading-relaxed">
            Calle Venustiano Carranza 3, Centro, Ocotlán de Morelos, Oax.
          </p>
        </div>
      </div>
    </div>

    <!-- Columna 3: Contacto -->
    <div class="space-y-5">
      <h3 class="font-bold text-base tracking-wide">Contacto</h3>
      <div class="space-y-3 text-sm">
        <p class="font-semibold text-white">Dra. Mónica Ortiz Rodríguez</p>
        <a
          href="tel:9511398701"
          class="flex items-center gap-2.5 text-slate-300 hover:text-accent transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-4 h-4 shrink-0"
          >
            <path
              fill-rule="evenodd"
              d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z"
              clip-rule="evenodd"></path>
          </svg>
          951 139 87 01
        </a>
        <a
          href="mailto:monica.ortizrg@gmail.com"
          class="flex items-center gap-2.5 text-slate-300 hover:text-accent transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="w-4 h-4 shrink-0"
          >
            <path
              d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"
            ></path>
            <path
              d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"
            ></path>
          </svg>
          monica.ortizrg@gmail.com
        </a>
      </div>
    </div>
  </div>

  <!-- Barra inferior -->
  <div class="sm:border-t sm:border-white/10 py-5">
    <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-slate-400 text-xs">
      <span>© {new Date().getFullYear()} Óptica del Centro. Todos los derechos reservados.</span>

      <div class="w-full border-t border-white/10 sm:hidden"></div>

      <div class="flex items-center gap-2.5 opacity-35">
        <span class="tracking-[0.2em]">Diseñado por</span>
        <img
          src="/faviconnicrosil.svg"
          alt="Nicrosil"
          width="14"
          height="14"
          class="brightness-0 invert"
        />
        <span class="tracking-[0.15em]">nicrosil.dev</span>
      </div>
    </div>
  </div>
</footer>
