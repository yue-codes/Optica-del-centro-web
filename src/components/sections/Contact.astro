---

<section
  id="contacto"
  class="relative overflow-hidden bg-gradient-to-br from-[#0d2a46] via-primary to-[#1e4a72] py-24"
>
  <!-- Decoraciones de fondo -->
  <div
    class="bg-accent/8 pointer-events-none absolute top-0 left-0 h-[500px] w-[500px] rounded-full blur-[140px]"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 opacity-10"
    style="background-image: radial-gradient(circle, #3aafb9 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <!-- Encabezado -->
    <span
      class="text-accent mb-3 inline-block text-sm font-semibold tracking-widest uppercase"
    >
      Estamos para atenderte
    </span>
    <h2 class="mb-4 text-4xl font-bold text-white lg:text-5xl">Contáctanos</h2>
    <p class="mx-auto mb-12 max-w-md text-slate-300">
      Agenda tu cita con la <strong class="text-white"
        >Dra. Mónica Ortiz Rodríguez</strong
      > y da el primer paso hacia una mejor salud visual.
    </p>

    <!-- CTA WhatsApp principal -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mb-14 inline-flex items-center gap-3 rounded-full bg-[#25D366] px-10 py-5 text-lg font-bold text-white shadow-2xl shadow-green-900/40 transition-all duration-200 hover:-translate-y-1 hover:bg-[#1ebe59] hover:shadow-green-900/60"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        class="h-6 w-6 shrink-0"
      >
        <path
          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
        ></path>
      </svg>
      Agendar cita por WhatsApp
    </a>

    <!-- Divider -->
    <div class="mb-10 flex items-center gap-4">
      <div class="h-px flex-1 bg-white/10"></div>
      <span class="text-sm text-slate-400">o contáctanos por</span>
      <div class="h-px flex-1 bg-white/10"></div>
    </div>

    <!-- Datos de contacto -->
    <div class="mb-10 flex flex-wrap justify-center gap-4">
      {
        contactos.map((c) => (
          <a
            href={c.href}
            class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-6 py-4 text-left transition-all duration-200 hover:border-accent/30 hover:bg-white/10"
          >
            <span class="text-accent" set:html={c.icono} />
            <div>
              <p class="text-xs text-slate-400">{c.label}</p>
              <p class="font-semibold text-white">{c.valor}</p>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Redes sociales -->
    <div class="flex justify-center gap-3">
      {
        redes.map((r) => (
          <a
            href={r.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={r.label}
            class="text-accent flex h-12 w-12 items-center justify-center rounded-full border border-white/10 bg-white/5 transition-all duration-200 hover:border-accent/40 hover:bg-accent/20"
            set:html={r.icono}
          />
        ))
      }
    </div>
  </div>
</section>
