---
const sucursales = [
  {
    ciudad: "Tlacolula",
    nombre: "Sucursal Tlacolula",
    direccion: "Nicolás Bravo #13, Tlacolula de Matamoros, C.P. 70400, Oaxaca.",
    horario: "Lun – Sáb: 10:00 – 18:00", // TODO: confirmar horario real
    mapsUrl:
      "https://maps.google.com/?q=Nicolás+Bravo+13+Tlacolula+de+Matamoros+Oaxaca",
    imagen:
      "https://images.unsplash.com/photo-1631217868264-e5b90bb7e133?auto=format&fit=crop&w=800&q=80",
  },
  {
    ciudad: "Ocotlán",
    nombre: "Sucursal Ocotlán",
    direccion:
      "Calle Venustiano Carranza #3, Centro, Ocotlán de Morelos, Oaxaca.",
    horario: "Lun – Sáb: 10:00 – 18:00", // TODO: confirmar horario real
    mapsUrl:
      "https://maps.google.com/?q=Venustiano+Carranza+3+Ocotlán+de+Morelos+Oaxaca",
    imagen:
      "https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?auto=format&fit=crop&w=800&q=80",
  },
];
---

<section id="sucursales" class="bg-white py-24">
  <div class="mx-auto max-w-5xl px-6">
    <!-- Encabezado -->
    <div class="mb-14 text-center">
      <span
        class="text-accent mb-3 inline-block text-sm font-semibold tracking-widest uppercase"
      >
        Dónde encontrarnos
      </span>
      <h2 class="text-primary text-4xl font-bold lg:text-5xl">Sucursales</h2>
      <p class="mx-auto mt-4 max-w-md text-slate-500">
        Contamos con dos ubicaciones en el Valle de Oaxaca para estar cerca de
        ti.
      </p>
    </div>

    <!-- Tarjetas -->
    <div class="space-y-6">
      {
        sucursales.map((s) => (
          <div class="flex flex-col overflow-hidden rounded-[32px] border border-slate-100 bg-white shadow-sm md:flex-row">
            <!-- Imagen -->
            <div class="relative h-64 md:h-auto md:w-1/2">
              <img
                src={s.imagen}
                alt={`Sucursal ${s.ciudad}`}
                class="h-full w-full object-cover"
              />
            </div>

            <!-- Info -->
            <div class="flex flex-col justify-between p-8 md:w-1/2">
              <div>
                <!-- Ciudad -->
                <div class="text-accent mb-4 flex items-center gap-2">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-5 w-5 shrink-0"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.013 3.5-4.751 3.5-8.336C20 6.945 16.364 3 12 3S4 6.945 4 11.004c0 3.585 1.556 6.323 3.5 8.336a19.578 19.578 0 002.683 2.282 16.974 16.974 0 001.144.742z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span class="text-sm font-bold tracking-widest uppercase">
                    {s.ciudad}
                  </span>
                </div>

                <!-- Nombre y dirección -->
                <h3 class="text-primary mb-2 text-xl font-bold">{s.nombre}</h3>
                <p class="mb-6 text-sm leading-relaxed text-slate-500">
                  {s.direccion}
                </p>
              </div>

              <div class="space-y-3">
                <!-- Botón Google Maps -->
                <a
                  href={s.mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="bg-primary hover:bg-accent flex items-center justify-center gap-2 rounded-xl py-3 text-sm font-bold text-white transition-colors duration-200"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="h-4 w-4"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M8.161 2.58a1.875 1.875 0 011.678 0l4.993 2.498c.106.052.23.052.336 0l3.869-1.935A1.875 1.875 0 0121.75 4.82v12.485c0 .71-.401 1.36-1.037 1.677l-4.875 2.437a1.875 1.875 0 01-1.676 0l-4.994-2.497a.375.375 0 00-.336 0l-3.868 1.935A1.875 1.875 0 012.25 19.18V6.695c0-.71.401-1.36 1.036-1.677l4.875-2.437zM9 6a.75.75 0 01.75.75V15a.75.75 0 01-1.5 0V6.75A.75.75 0 019 6zm6.75 3a.75.75 0 00-1.5 0v8.25a.75.75 0 001.5 0V9z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Google Maps
                </a>

                <!-- Horario -->
                <p class="text-center text-xs text-slate-400">{s.horario}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
