---
const sucursales = [
  {
    nombre: "Sucursal Tlacolula",
    direccion: "Nicolás Bravo #13",
    ciudad: "Tlacolula de Matamoros, Oaxaca",
    cp: "C.P. 70400",
    mapsUrl: "https://maps.google.com/?q=Nicolás+Bravo+13+Tlacolula+de+Matamoros+Oaxaca",
  },
  {
    nombre: "Sucursal Ocotlán",
    direccion: "Calle Venustiano Carranza #3, Centro",
    ciudad: "Ocotlán de Morelos, Oaxaca",
    cp: "",
    mapsUrl: "https://maps.google.com/?q=Venustiano+Carranza+3+Ocotlán+de+Morelos+Oaxaca",
  },
];
---

<section id="sucursales" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Encabezado -->
    <div class="mb-16 text-center">
      <span
        class="text-accent mb-3 inline-block text-sm font-semibold tracking-widest uppercase"
      >
        Dónde encontrarnos
      </span>
      <h2 class="text-primary text-4xl font-bold lg:text-5xl">Sucursales</h2>
      <p class="mx-auto mt-4 max-w-md text-slate-500">
        Contamos con dos ubicaciones en el Valle de Oaxaca para estar cerca de
        ti.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      {
        sucursales.map((s) => (
          <div class="group relative overflow-hidden rounded-3xl border border-slate-100 bg-white shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <!-- Mapa placeholder -->
            <div class="from-primary/80 to-primary relative h-48 overflow-hidden bg-gradient-to-br">
              <!-- Grid decorativo imitando mapa -->
              <div
                class="absolute inset-0 opacity-20"
                style="background-image: linear-gradient(#3aafb9 1px, transparent 1px), linear-gradient(90deg, #3aafb9 1px, transparent 1px); background-size: 40px 40px;"
              />
              <!-- Pin central -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="relative">
                  <div class="bg-accent flex h-14 w-14 items-center justify-center rounded-full shadow-xl">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-7 w-7 text-white"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.013 3.5-4.751 3.5-8.336C20 6.945 16.364 3 12 3S4 6.945 4 11.004c0 3.585 1.556 6.323 3.5 8.336a19.578 19.578 0 002.683 2.282 16.974 16.974 0 001.144.742z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </div>
                  <div class="bg-accent/30 absolute -inset-2 animate-ping rounded-full" />
                </div>
              </div>
              <!-- Nombre de sucursal sobre el mapa -->
              <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/40 to-transparent px-6 py-4">
                <span class="text-sm font-semibold text-white/80 uppercase tracking-wider">
                  {s.nombre}
                </span>
              </div>
            </div>

            <!-- Info -->
            <div class="p-7 space-y-4">
              <div class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="text-accent mt-0.5 h-5 w-5 shrink-0"
                >
                  <path
                    fill-rule="evenodd"
                    d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.013 3.5-4.751 3.5-8.336C20 6.945 16.364 3 12 3S4 6.945 4 11.004c0 3.585 1.556 6.323 3.5 8.336a19.578 19.578 0 002.683 2.282 16.974 16.974 0 001.144.742z"
                    clip-rule="evenodd"
                  />
                </svg>
                <div>
                  <p class="text-primary font-semibold">{s.direccion}</p>
                  <p class="text-slate-500 text-sm">{s.ciudad}</p>
                  {s.cp && <p class="text-slate-400 text-xs mt-0.5">{s.cp}</p>}
                </div>
              </div>

              <a
                href={s.mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="border-accent text-accent hover:bg-accent inline-flex w-full items-center justify-center gap-2 rounded-full border py-3 text-sm font-semibold transition-all duration-200 hover:text-white"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="h-4 w-4"
                >
                  <path
                    fill-rule="evenodd"
                    d="M8.161 2.58a1.875 1.875 0 011.678 0l4.993 2.498c.106.052.23.052.336 0l3.869-1.935A1.875 1.875 0 0121.75 4.82v12.485c0 .71-.401 1.36-1.037 1.677l-4.875 2.437a1.875 1.875 0 01-1.676 0l-4.994-2.497a.375.375 0 00-.336 0l-3.868 1.935A1.875 1.875 0 012.25 19.18V6.695c0-.71.401-1.36 1.036-1.677l4.875-2.437zM9 6a.75.75 0 01.75.75V15a.75.75 0 01-1.5 0V6.75A.75.75 0 019 6zm6.75 3a.75.75 0 00-1.5 0v8.25a.75.75 0 001.5 0V9z"
                    clip-rule="evenodd"
                  />
                </svg>
                Cómo llegar
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
