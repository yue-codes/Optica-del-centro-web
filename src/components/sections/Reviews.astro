---
import ReviewsCarousel from "@components/sections/ReviewsCarousel";
---

<section id="resenas" class="relative bg-primary py-24 overflow-hidden">
  <!-- Glow de fondo -->
  <div
    class="bg-accent/8 pointer-events-none absolute top-0 right-0 h-[500px] w-[500px] rounded-full blur-[140px]"
  >
  </div>

  <div class="relative mx-auto max-w-7xl px-6">
    <!-- Encabezado -->
    <div class="mb-16 text-center">
      <span
        class="text-accent mb-3 inline-block text-sm font-semibold tracking-widest uppercase"
      >
        Lo que dicen nuestros pacientes
      </span>
      <h2 class="text-4xl font-bold text-white lg:text-5xl">Reseñas</h2>
    </div>

    <ReviewsCarousel client:visible />
  </div>
</section>
