---
const optometric = [
  "Miopía",
  "Hipermetropía",
  "Astigmatismo",
  "Presbicia (vista cansada)",
  "Adaptación de lentes de contacto",
  "Terapia visual pediátrica",
];

const medical = [
  "Glaucoma (diagnóstico y control)",
  "Conjuntivitis alérgica, bacteriana y viral",
  "Pterigion o carnosidad (tratamiento médico y quirúrgico)",
  "Retinopatía diabética",
  "Diagnóstico de cataratas",
  "Orzuelos",
];
---

<section id="servicios" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Encabezado -->
    <div class="mb-16 text-center">
      <span
        class="text-accent mb-3 inline-block text-sm font-semibold tracking-widest uppercase"
      >
        Lo que ofrecemos
      </span>
      <h2 class="text-primary text-4xl font-bold lg:text-5xl">
        Nuestros Servicios
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-slate-500">
        Atención especializada para cuidar tu salud visual en todas sus
        dimensiones, desde la consulta de rutina hasta el tratamiento médico.
      </p>
    </div>

    <!-- Tarjetas de servicios -->
    <div class="grid gap-8 md:grid-cols-2">
      <!-- Consulta Optométrica -->
      <div
        class="group relative overflow-hidden rounded-3xl border border-slate-100 bg-white p-8 shadow-lg transition-shadow duration-300 hover:shadow-xl"
      >
        <!-- Barra top accent -->
        <div class="bg-accent absolute top-0 left-0 h-1 w-full"></div>

        <!-- Icono -->
        <div
          class="bg-accent/10 mb-6 flex h-14 w-14 items-center justify-center rounded-2xl"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="text-accent h-7 w-7"
          >
            <path d="M12 15a3 3 0 100-6 3 3 0 000 6z"></path>
            <path
              fill-rule="evenodd"
              d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 010-1.113zM17.25 12a5.25 5.25 0 11-10.5 0 5.25 5.25 0 0110.5 0z"
              clip-rule="evenodd"></path>
          </svg>
        </div>

        <h3 class="text-primary mb-6 text-xl font-bold">
          Consulta Optométrica
        </h3>

        <ul class="space-y-3">
          {
            optometric.map((item) => (
              <li class="flex items-start gap-3 text-slate-600">
                <span class="bg-accent/15 mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="text-accent h-3 w-3"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Consultas Médicas -->
      <div
        class="group relative overflow-hidden rounded-3xl border border-slate-100 bg-white p-8 shadow-lg transition-shadow duration-300 hover:shadow-xl"
      >
        <!-- Barra top primary -->
        <div class="bg-primary absolute top-0 left-0 h-1 w-full"></div>

        <!-- Icono -->
        <div
          class="bg-primary/10 mb-6 flex h-14 w-14 items-center justify-center rounded-2xl"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="text-primary h-7 w-7"
          >
            <path
              fill-rule="evenodd"
              d="M11.484 2.17a.75.75 0 011.032 0 11.209 11.209 0 007.877 3.08.75.75 0 01.722.515 12.74 12.74 0 01.635 3.985c0 5.942-4.064 10.933-9.563 12.348a.749.749 0 01-.388 0C6.314 20.683 2.25 15.692 2.25 9.75c0-1.39.223-2.73.635-3.985a.75.75 0 01.722-.516l.143.001c2.996 0 5.718-1.17 7.734-3.08zM12 8.25a.75.75 0 01.75.75v3.75a.75.75 0 01-1.5 0V9a.75.75 0 01.75-.75zM12 15a.75.75 0 000 1.5.75.75 0 000-1.5z"
              clip-rule="evenodd"></path>
          </svg>
        </div>

        <h3 class="text-primary mb-6 text-xl font-bold">Consultas Médicas</h3>

        <ul class="space-y-3">
          {
            medical.map((item) => (
              <li class="flex items-start gap-3 text-slate-600">
                <span class="bg-primary/10 mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="text-primary h-3 w-3"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Banner: Lentes graduados -->
    <div class="mt-8 overflow-hidden rounded-3xl shadow-xl">
      <div class="relative h-[420px] md:h-80">
        <!-- Imagen de fondo -->
        <img
          src="/servicioanteojos.jpg"
          alt="Lentes graduados"
          class="h-full w-full object-cover"
        />

        <!-- Overlay gradiente izquierda para texto -->
        <div
          class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/20 to-transparent"
        ></div>

        <!-- Texto inferior izquierdo -->
        <div class="absolute bottom-6 left-6 md:bottom-8 md:left-8">
          <p class="text-sm font-semibold tracking-widest text-white/80 uppercase">
            Incluye armazón + graduación
          </p>
        </div>

        <!-- Badge de precio: esquina superior derecha -->
        <div
          class="absolute top-6 right-6 md:top-8 md:right-8 bg-primary rounded-2xl px-5 py-4 text-right shadow-2xl border border-accent/30"
        >
          <p class="text-xs font-semibold text-slate-300 uppercase tracking-wider">
            Lentes graduados desde
          </p>
          <p class="text-4xl font-black text-white leading-none mt-1">
            $1,500
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
